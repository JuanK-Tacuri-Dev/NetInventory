@page "/error-logs"
@attribute [Authorize]
@inject ErrorLogService ErrorLogSvc
@inject IJSRuntime JS
@inject NavigationManager Navigation

<PageTitle>Error Log - NetInventory</PageTitle>

<div class="page-title-box">
    <h4><i class="bi bi-exclamation-triangle mr-2"></i>Error Log</h4>
    <div style="display:flex;gap:8px;">
        <button class="btn btn-outline-danger btn-sm" @onclick="SimulateError" disabled="@simulating">
            @if (simulating)
            {
                <span class="spinner-border spinner-border-sm mr-1"></span>
            }
            else
            {
                <i class="bi bi-lightning-charge mr-1"></i>
            }
            Simular Error
        </button>
        <button class="btn btn-outline-primary btn-sm" @onclick="Reload" disabled="@loading">
            <i class="bi bi-arrow-clockwise mr-1"></i> Actualizar
        </button>
    </div>
</div>

<div class="card">
    <div class="card-body">
        <div class="card-title d-flex align-items-center justify-content-between">
            <span>Registro de errores del sistema</span>
            @if (pagedResult.TotalCount > 0)
            {
                <span class="badge badge-pill badge-danger" style="font-size:11px;font-weight:600;">
                    @pagedResult.TotalCount errores
                </span>
            }
        </div>

        @if (loading)
        {
            <div class="text-center py-5">
                <div class="spinner-border" style="color:#24356a;" role="status"></div>
                <p class="mt-2 text-muted" style="font-size:12px;">Cargando registros...</p>
            </div>
        }
        else
        {
            <div class="table-scroll-wrap">
                <table class="table table-bordered table-hover" style="table-layout:fixed;min-width:860px;width:100%;">
                    <colgroup>
                        <col style="width:9%;" />
                        <col style="width:10%;" />
                        <col style="width:14%;" />
                        <col style="width:14%;" />
                        <col style="width:30%;" />
                        <col style="width:7%;" />
                        <col style="width:16%;" />
                    </colgroup>
                    <thead>
                        <tr>
                            <th class="text-center">Acciones</th>
                            <th>Ref.</th>
                            <th>Fecha</th>
                            <th>Tipo de excepción</th>
                            <th>Mensaje</th>
                            <th>Método</th>
                            <th>Endpoint</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (pagedResult.Items.Count == 0)
                        {
                            <tr>
                                <td colspan="7" class="text-center py-5">
                                    <i class="bi bi-check-circle" style="font-size:48px;color:#34c38f;display:block;"></i>
                                    <span class="text-muted">No hay errores registrados. ¡El sistema funciona correctamente!</span>
                                </td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var log in pagedResult.Items)
                            {
                                <tr>
                                    <td class="text-center">
                                        <div class="btn-group btn-group-sm">
                                            @if (!string.IsNullOrEmpty(log.StackTrace))
                                            {
                                                <button class="btn btn-outline-secondary btn-icon"
                                                        title="Ver stack trace"
                                                        @onclick="() => ShowStack(log)">
                                                    <i class="bi bi-code-slash"></i>
                                                </button>
                                            }
                                            @if (!string.IsNullOrEmpty(log.CorrelationId))
                                            {
                                                <button class="btn btn-outline-info btn-icon"
                                                        title="Ver solicitud HTTP asociada"
                                                        @onclick="() => GoToAuditLog(log.CorrelationId)">
                                                    <i class="bi bi-arrow-right-circle"></i>
                                                </button>
                                            }
                                        </div>
                                    </td>
                                    <td>
                                        <span class="badge badge-pill"
                                              style="font-size:10px;font-weight:700;background:#24356a;color:#fff;letter-spacing:.5px;cursor:pointer;"
                                              title="Código de referencia — compartir con soporte"
                                              @onclick="() => CopyRef(log.ReferenceCode)">
                                            @log.ReferenceCode
                                        </span>
                                    </td>
                                    <td style="font-size:12px;">@log.OccurredAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm:ss")</td>
                                    <td>
                                        <span class="badge badge-pill badge-danger" style="font-size:10px;font-weight:600;">
                                            @log.ExceptionType
                                        </span>
                                    </td>
                                    <td style="font-size:12px;">
                                        <span title="@log.Message">
                                            @(log.Message.Length > 80 ? log.Message[..80] + "..." : log.Message)
                                        </span>
                                    </td>
                                    <td>
                                        <span class="badge badge-pill"
                                              style="font-size:10px;font-weight:700;background:@GetMethodColor(log.Method);color:#fff;">
                                            @log.Method
                                        </span>
                                    </td>
                                    <td><code style="font-size:11px;">@log.Path</code></td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>

            @if (pagedResult.TotalCount > 0)
            {
                <div class="pagination-bar">
                    <span class="pagination-info">
                        Mostrando @((currentPage - 1) * pageSize + 1)–@(Math.Min(currentPage * pageSize, pagedResult.TotalCount))
                        de <strong>@pagedResult.TotalCount</strong> errores
                    </span>
                    <div class="d-flex align-items-center" style="gap:12px;">
                        <div class="d-flex align-items-center" style="gap:6px;">
                            <span style="font-size:12px;color:#6c757d;white-space:nowrap;">Por página:</span>
                            <select @bind="pageSize" @bind:after="ResetAndLoad"
                                    style="font-size:12px;padding:5px 8px;border:1px solid #dee2e6;border-radius:4px;color:#24356a;font-weight:600;cursor:pointer;background:#fff;outline:none;height:30px;">
                                <option value="5">5</option>
                                <option value="10">10</option>
                                <option value="20">20</option>
                                <option value="50">50</option>
                            </select>
                        </div>
                        <nav aria-label="Paginación">
                            <ul class="pagination pagination-sm mb-0">
                                <li class="page-item @(!pagedResult.HasPreviousPage ? "disabled" : "")">
                                    <button class="page-link" @onclick="PreviousPage">&laquo;</button>
                                </li>
                                @{
                                    var (winStart, winEnd) = GetPageWindow();
                                }
                                @if (winStart > 1)
                                {
                                    <li class="page-item">
                                        <button class="page-link" @onclick='() => GoToPage(1)'>1</button>
                                    </li>
                                    @if (winStart > 2)
                                    {
                                        <li class="page-item disabled"><span class="page-link">…</span></li>
                                    }
                                }
                                @for (var i = winStart; i <= winEnd; i++)
                                {
                                    var pg = i;
                                    <li class="page-item @(pg == currentPage ? "active" : "")">
                                        <button class="page-link" @onclick="() => GoToPage(pg)">@pg</button>
                                    </li>
                                }
                                @if (winEnd < pagedResult.TotalPages)
                                {
                                    @if (winEnd < pagedResult.TotalPages - 1)
                                    {
                                        <li class="page-item disabled"><span class="page-link">…</span></li>
                                    }
                                    <li class="page-item">
                                        <button class="page-link" @onclick='() => GoToPage(pagedResult.TotalPages)'>@pagedResult.TotalPages</button>
                                    </li>
                                }
                                <li class="page-item @(!pagedResult.HasNextPage ? "disabled" : "")">
                                    <button class="page-link" @onclick="NextPage">&raquo;</button>
                                </li>
                            </ul>
                        </nav>
                    </div>
                </div>
            }
        }
    </div>
</div>

@code {
    private PagedResult<ErrorLogModel> pagedResult = new();
    private bool loading;
    private bool simulating;
    private int currentPage = 1;
    private int pageSize = 10;
    private int _loadSeq;

    protected override async Task OnInitializedAsync() => await LoadLogs();

    private async Task LoadLogs()
    {
        var seq = ++_loadSeq;
        loading = true;
        var result = await ErrorLogSvc.GetPagedAsync(currentPage, pageSize);
        if (seq == _loadSeq)
        {
            pagedResult = result;
            loading = false;
        }
    }

    private async Task Reload() { currentPage = 1; await LoadLogs(); }
    private async Task ResetAndLoad() { currentPage = 1; await LoadLogs(); }
    private async Task GoToPage(int page) { currentPage = page; await LoadLogs(); }
    private async Task PreviousPage() { if (pagedResult.HasPreviousPage) { currentPage--; await LoadLogs(); } }
    private async Task NextPage() { if (pagedResult.HasNextPage) { currentPage++; await LoadLogs(); } }

    private (int Start, int End) GetPageWindow()
    {
        const int windowSize = 10;
        const int half = windowSize / 2;
        var start = Math.Max(1, currentPage - half);
        var end = Math.Min(pagedResult.TotalPages, start + windowSize - 1);
        start = Math.Max(1, end - windowSize + 1);
        return (start, end);
    }

    private async Task CopyRef(string refCode)
    {
        await JS.InvokeVoidAsync("navigator.clipboard.writeText", refCode);
        await JS.InvokeVoidAsync("Swal.fire", new
        {
            toast = true,
            position = "top-end",
            icon = "success",
            title = $"Copiado: {refCode}",
            showConfirmButton = false,
            timer = 1800
        });
    }

    private async Task ShowStack(ErrorLogModel log)
    {
        var stackHtml = "<pre style='text-align:left;font-size:11px;max-height:400px;overflow:auto;background:#f8f9fa;padding:12px;border-radius:4px;'>"
            + System.Net.WebUtility.HtmlEncode(log.StackTrace)
            + "</pre>";

        await JS.InvokeVoidAsync("Swal.fire", new
        {
            title = log.ExceptionType,
            html = $"<p style='font-size:11px;color:#74788d;margin-bottom:8px;'>Ref: <strong>{log.ReferenceCode}</strong></p>" + stackHtml,
            width = "800px",
            confirmButtonColor = "#24356a",
            confirmButtonText = "Cerrar"
        });
    }

    private async Task SimulateError()
    {
        simulating = true;
        var msg = $"Error de prueba generado desde la UI — {DateTime.Now:HH:mm:ss}";
        await ErrorLogSvc.SimulateErrorAsync(msg);
        await Task.Delay(600);
        await Reload();
        simulating = false;
    }

    private void GoToAuditLog(string correlationId)
        => Navigation.NavigateTo("/audit-logs?correlationId=" + Uri.EscapeDataString(correlationId));

    private static string GetMethodColor(string method) => method switch
    {
        "GET"    => "#50a5f1",
        "POST"   => "#34c38f",
        "PUT"    => "#f1b44c",
        "DELETE" => "#f46a6a",
        _        => "#74788d"
    };
}
