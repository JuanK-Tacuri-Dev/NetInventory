@page "/products/{Id:guid}"
@attribute [Authorize]
@inject ProductService Products
@inject GeneralValueService GeneralValues
@inject NavigationManager Navigation

<PageTitle>Detalle de producto - NetInventory</PageTitle>

@if (loading)
{
    <div class="text-center py-5">
        <div class="spinner-border" style="color:#24356a;" role="status"></div>
    </div>
}
else if (product is null)
{
    <div class="alert alert-warning">Producto no encontrado.</div>
}
else
{
    <div class="page-title-box">
        <h4><i class="bi bi-box-seam mr-2"></i>@product.Name</h4>
        <div class="d-flex" style="gap:8px;">
            <a href="/products" class="btn btn-outline-secondary btn-sm">
                <i class="bi bi-arrow-left mr-1"></i> Volver
            </a>
            <a href="/products/@product.Id/edit" class="btn btn-outline-primary btn-sm">
                <i class="bi bi-pencil mr-1"></i> Editar
            </a>
        </div>
    </div>

    <!-- Datos del producto -->
    <div class="card">
        <div class="card-header">
            <i class="bi bi-info-circle mr-2"></i>Información del producto
        </div>
        <div class="card-body">
            <div class="row" style="row-gap:0;">
                <div class="col-sm-4 col-6" style="padding:8px 16px;border-bottom:1px solid #f1f1f1;">
                    <div style="font-size:11px;font-weight:600;color:#6c757d;text-transform:uppercase;letter-spacing:.5px;">SKU</div>
                    <div style="margin-top:3px;"><code style="color:#24356a;font-size:13px;">@product.SKU</code></div>
                </div>
                <div class="col-sm-4 col-6" style="padding:8px 16px;border-bottom:1px solid #f1f1f1;">
                    <div style="font-size:11px;font-weight:600;color:#6c757d;text-transform:uppercase;letter-spacing:.5px;">Categoría</div>
                    <div style="margin-top:3px;">
                        <span class="badge badge-pill badge-light" style="border:1px solid #dee2e6;color:#495057;font-size:12px;">
                            @(product.CategoryDescription is { Length: > 0 } d ? d : product.CategoryCode)
                        </span>
                    </div>
                </div>
                <div class="col-sm-4 col-6" style="padding:8px 16px;border-bottom:1px solid #f1f1f1;">
                    <div style="font-size:11px;font-weight:600;color:#6c757d;text-transform:uppercase;letter-spacing:.5px;">Precio unitario</div>
                    <div style="margin-top:3px;font-size:15px;font-weight:700;color:#24356a;">$@product.UnitPrice.ToString("N2")</div>
                </div>
                <div class="col-sm-4 col-6" style="padding:8px 16px;border-bottom:1px solid #f1f1f1;">
                    <div style="font-size:11px;font-weight:600;color:#6c757d;text-transform:uppercase;letter-spacing:.5px;">Stock actual</div>
                    <div style="margin-top:3px;">
                        <strong style="font-size:15px;">@product.QuantityInStock</strong>
                        @if (product.MinStock > 0 && product.QuantityInStock < product.MinStock)
                        {
                            <span class="badge-low-stock ml-2">Stock bajo</span>
                        }
                        else
                        {
                            <span class="badge badge-pill badge-success ml-2" style="font-size:10px;">OK</span>
                        }
                    </div>
                </div>
                <div class="col-sm-4 col-6" style="padding:8px 16px;border-bottom:1px solid #f1f1f1;">
                    <div style="font-size:11px;font-weight:600;color:#6c757d;text-transform:uppercase;letter-spacing:.5px;">Stock mínimo</div>
                    <div style="margin-top:3px;font-size:14px;">@product.MinStock</div>
                </div>
                <div class="col-sm-4 col-6" style="padding:8px 16px;border-bottom:1px solid #f1f1f1;">
                    <div style="font-size:11px;font-weight:600;color:#6c757d;text-transform:uppercase;letter-spacing:.5px;">Stock máximo</div>
                    <div style="margin-top:3px;font-size:14px;">@(product.MaxStock > 0 ? product.MaxStock.ToString() : "—")</div>
                </div>
                <div class="col-sm-4 col-6" style="padding:8px 16px;">
                    <div style="font-size:11px;font-weight:600;color:#6c757d;text-transform:uppercase;letter-spacing:.5px;">Creado</div>
                    <div style="margin-top:3px;font-size:13px;">@product.CreatedAt.ToString("dd/MM/yyyy HH:mm")</div>
                </div>
            </div>
        </div>
    </div>

    <!-- Historial de movimientos -->
    <div class="card">
        <div class="card-header">
            <i class="bi bi-clock-history mr-2"></i>Historial de movimientos
        </div>
        <div class="card-body">
            @if (movements.Count == 0)
            {
                <div class="text-center py-3">
                    <i class="bi bi-inbox" style="font-size:36px;color:#ced4da;display:block;"></i>
                    <p class="mt-2 text-muted" style="font-size:12px;">Sin movimientos registrados.</p>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-bordered table-hover">
                        <thead>
                            <tr>
                                <th class="text-center" style="width:100px;">Tipo</th>
                                <th class="text-center" style="width:80px;">Cantidad</th>
                                <th>Motivo</th>
                                <th style="width:140px;">Fecha</th>
                                <th style="width:140px;">Registrado por</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var m in movements)
                            {
                                <tr>
                                    <td class="text-center">
                                        @if (m.Type == "Inbound")
                                        {
                                            <span class="badge-type-in"><i class="bi bi-arrow-up mr-1"></i>Entrada</span>
                                        }
                                        else
                                        {
                                            <span class="badge-type-out"><i class="bi bi-arrow-down mr-1"></i>Salida</span>
                                        }
                                    </td>
                                    <td class="text-center font-weight-600">@m.Quantity</td>
                                    <td style="font-size:12px;color:#6c757d;">@(string.IsNullOrEmpty(m.Reason) ? "—" : m.Reason)</td>
                                    <td>@m.Timestamp.ToString("dd/MM/yyyy HH:mm")</td>
                                    <td>@(m.CreatedBy ?? "-")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
}

@code {
    [Parameter] public Guid Id { get; set; }

    private ProductModel? product;
    private List<StockMovementModel> movements = [];
    private List<GeneralValueModel> _categories = [];
    private bool loading = true;

    protected override async Task OnInitializedAsync()
    {
        var categoriesTask = GeneralValues.GetByTableIdAsync(1001);
        product = await Products.GetByIdAsync(Id);
        movements = await Products.GetMovementsAsync(Id);
        _categories = await categoriesTask;

        if (product is not null && string.IsNullOrEmpty(product.CategoryDescription))
            product.CategoryDescription = _categories.FirstOrDefault(c => c.Code == product.CategoryCode)?.Description ?? product.CategoryCode;

        loading = false;
    }
}
