@page "/products"
@attribute [Authorize]
@inject ProductService Products
@inject NavigationManager Navigation
@inject IJSRuntime JS

<PageTitle>Productos - NetInventory</PageTitle>

<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:16px;">
    <h2>Productos</h2>
    <button @onclick='() => Navigation.NavigateTo("/products/new")' style="padding:8px 16px;cursor:pointer;">
        + Nuevo Producto
    </button>
</div>

<div style="display:flex;gap:16px;align-items:center;margin-bottom:16px;flex-wrap:wrap;">
    <div>
        <label>Categoría: </label>
        <input @bind="categoryFilter" @bind:event="oninput" @bind:after="ResetAndLoad"
               placeholder="Filtrar categoría" style="padding:6px;margin-left:4px;" />
    </div>
    <label style="display:flex;align-items:center;gap:6px;cursor:pointer;">
        <input type="checkbox" @bind="lowStockOnly" @bind:after="ResetAndLoad" />
        Solo stock bajo
    </label>
    <div>
        <label>Por página: </label>
        <select @bind="pageSize" @bind:after="ResetAndLoad" style="padding:6px;margin-left:4px;">
            <option value="5">5</option>
            <option value="10">10</option>
            <option value="20">20</option>
            <option value="50">50</option>
        </select>
    </div>
</div>

@if (loading)
{
    <p>Cargando...</p>
}
else if (pagedResult.Items.Count == 0)
{
    <p>No hay productos.</p>
}
else
{
    <table style="width:100%;border-collapse:collapse;">
        <thead>
            <tr style="border-bottom:2px solid #dee2e6;text-align:left;">
                <th style="padding:8px;">Nombre</th>
                <th style="padding:8px;">SKU</th>
                <th style="padding:8px;">Categoría</th>
                <th style="padding:8px;">Stock</th>
                <th style="padding:8px;">Precio unit.</th>
                <th style="padding:8px;">Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var p in pagedResult.Items)
            {
                <tr style="border-bottom:1px solid #dee2e6; @(p.QuantityInStock < 10 ? "background-color:#fff3cd;" : "")">
                    <td style="padding:8px;">@p.Name</td>
                    <td style="padding:8px;">@p.SKU</td>
                    <td style="padding:8px;">@p.Category</td>
                    <td style="padding:8px;">
                        @p.QuantityInStock
                        <LowStockBadge Quantity="@p.QuantityInStock" />
                    </td>
                    <td style="padding:8px;">@p.UnitPrice.ToString("C")</td>
                    <td style="padding:8px;display:flex;gap:6px;">
                        <button @onclick='() => Navigation.NavigateTo($"/products/{p.Id}")' style="cursor:pointer;padding:4px 10px;">Ver</button>
                        <button @onclick='() => Navigation.NavigateTo($"/products/{p.Id}/edit")' style="cursor:pointer;padding:4px 10px;">Editar</button>
                        <button @onclick='() => ConfirmDelete(p)' style="cursor:pointer;padding:4px 10px;background:#dc3545;color:white;border:none;">Eliminar</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <div style="display:flex;align-items:center;gap:12px;margin-top:16px;justify-content:space-between;">
        <span style="font-size:0.9em;color:#666;">
            Mostrando @((currentPage - 1) * pageSize + 1)–@(Math.Min(currentPage * pageSize, pagedResult.TotalCount)) de @pagedResult.TotalCount productos
        </span>
        <div style="display:flex;gap:6px;">
            <button @onclick="PreviousPage" disabled="@(!pagedResult.HasPreviousPage)" style="padding:4px 12px;cursor:pointer;">
                &laquo; Anterior
            </button>
            @for (var i = 1; i <= pagedResult.TotalPages; i++)
            {
                var pageNum = i;
                <button @onclick="() => GoToPage(pageNum)"
                        style="padding:4px 12px;cursor:pointer;@(pageNum == currentPage ? "background:#0d6efd;color:white;border-color:#0d6efd;" : "")">
                    @pageNum
                </button>
            }
            <button @onclick="NextPage" disabled="@(!pagedResult.HasNextPage)" style="padding:4px 12px;cursor:pointer;">
                Siguiente &raquo;
            </button>
        </div>
    </div>
}

@code {
    private PagedResult<ProductModel> pagedResult = new();
    private string categoryFilter = string.Empty;
    private bool lowStockOnly;
    private bool loading;
    private int currentPage = 1;
    private int pageSize = 10;

    protected override async Task OnInitializedAsync() => await LoadProducts();

    private async Task LoadProducts()
    {
        loading = true;
        pagedResult = await Products.GetPagedAsync(categoryFilter, lowStockOnly, 10, currentPage, pageSize);
        loading = false;
    }

    private async Task ResetAndLoad()
    {
        currentPage = 1;
        await LoadProducts();
    }

    private async Task GoToPage(int page)
    {
        currentPage = page;
        await LoadProducts();
    }

    private async Task PreviousPage()
    {
        if (pagedResult.HasPreviousPage)
        {
            currentPage--;
            await LoadProducts();
        }
    }

    private async Task NextPage()
    {
        if (pagedResult.HasNextPage)
        {
            currentPage++;
            await LoadProducts();
        }
    }

    private async Task ConfirmDelete(ProductModel product)
    {
        var confirmed = await JS.InvokeAsync<bool>("confirm", $"¿Eliminar '{product.Name}'?");
        if (!confirmed) return;

        var ok = await Products.DeleteAsync(product.Id);
        if (ok) await LoadProducts();
    }
}
