@page "/products/new"
@page "/products/{Id:guid}/edit"
@attribute [Authorize]
@inject ProductService Products
@inject GeneralValueService GeneralValues
@inject NavigationManager Navigation
@inject IJSRuntime JS

<PageTitle>@(Id is null ? Labels.Product_NewTitle : Labels.Product_EditTitle) - NetInventory</PageTitle>

<div class="page-title-box">
    <h4>
        <i class="bi bi-@(Id is null ? "plus-circle" : "pencil-square") mr-2"></i>
        @(Id is null ? Labels.Product_New : Labels.Product_Edit)
    </h4>
    <a href="/products" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left mr-1"></i> @Labels.Action_Back
    </a>
</div>

<div class="row">
    <div class="col-lg-7 col-md-10">
        <div class="card">
            <div class="card-header">
                <i class="bi bi-box-seam mr-2"></i>
                @(Id is null ? Labels.Product_NewSubtitle : Labels.Product_EditSubtitle)
            </div>
            <div class="card-body">
                @if (loading)
                {
                    <div class="text-center py-4">
                        <div class="spinner-border" style="color:#24356a;" role="status"></div>
                    </div>
                }
                else
                {
                    <EditForm Model="createModel" OnValidSubmit="HandleSubmit">
                        <DataAnnotationsValidator />

                        <div class="form-group">
                            <label>Nombre <span class="text-danger">*</span></label>
                            <InputText @bind-Value="createModel.Name" class="form-control" placeholder="Ej: Laptop HP 15" />
                            <ValidationMessage For="() => createModel.Name" />
                        </div>

                        <div class="form-group">
                            <label>SKU <span class="text-danger">*</span></label>
                            <InputText @bind-Value="createModel.SKU" disabled="@(Id is not null)" class="form-control"
                                       placeholder="Ej: LAP-HP-001"
                                       style="@(Id is not null ? "background-color:#f8f9fa;" : "")" />
                            @if (Id is not null)
                            {
                                <small class="text-muted" style="font-size:11px;">
                                    <i class="bi bi-info-circle mr-1"></i>@Labels.Product_SkuImmutable
                                </small>
                            }
                            <ValidationMessage For="() => createModel.SKU" />
                        </div>

                        <div class="form-group">
                            <label>Categoría <span class="text-danger">*</span></label>
                            <select class="form-control" value="@createModel.CategoryCode" @onchange="OnCategoryChange">
                                <option value="">Seleccionar categoría...</option>
                                @foreach (var cat in _categories)
                                {
                                    <option value="@cat.Code">@cat.Description</option>
                                }
                            </select>
                            <ValidationMessage For="() => createModel.CategoryCode" />
                        </div>

                        <div class="form-group">
                            <label>Precio unitario (USD) <span class="text-danger">*</span></label>
                            <div class="input-group">
                                <div class="input-group-prepend">
                                    <span class="input-group-text bg-white font-weight-600">$</span>
                                </div>
                                <InputNumber @bind-Value="createModel.UnitPrice" class="form-control" placeholder="0.00" />
                            </div>
                            <ValidationMessage For="() => createModel.UnitPrice" />
                        </div>

                        <div class="row">
                            <div class="col-sm-6">
                                <div class="form-group">
                                    <label>Stock mínimo</label>
                                    <InputNumber @bind-Value="createModel.MinStock" class="form-control" min="0" />
                                    <small class="text-muted" style="font-size:11px;">Alerta de stock bajo bajo este valor</small>
                                    <ValidationMessage For="() => createModel.MinStock" />
                                </div>
                            </div>
                            <div class="col-sm-6">
                                <div class="form-group">
                                    <label>Stock máximo</label>
                                    <InputNumber @bind-Value="createModel.MaxStock" class="form-control" min="0" />
                                    <small class="text-muted" style="font-size:11px;">Referencia de capacidad máxima</small>
                                    <ValidationMessage For="() => createModel.MaxStock" />
                                </div>
                            </div>
                        </div>

                        @if (!string.IsNullOrEmpty(errorMessage))
                        {
                            <div class="alert alert-danger py-2 mb-3" style="font-size:12px;">
                                <i class="bi bi-exclamation-circle mr-1"></i> @errorMessage
                            </div>
                        }

                        <div class="d-flex mt-3" style="gap:8px;">
                            <button type="submit" disabled="@saving" class="btn btn-principal" style="min-width:110px;">
                                @if (saving)
                                {
                                    <span class="spinner-border spinner-border-sm mr-1" role="status"></span>
                                    <span>Guardando...</span>
                                }
                                else
                                {
                                    <i class="bi bi-check-lg mr-1"></i>
                                    <span>@Labels.Action_Save</span>
                                }
                            </button>
                            <a href="/products" class="btn btn-outline-secondary">@Labels.Action_Cancel</a>
                        </div>
                    </EditForm>
                }
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter] public Guid? Id { get; set; }

    private CreateProductRequest createModel = new();
    private bool loading;
    private bool saving;
    private string? errorMessage;

    private List<GeneralValueModel> _categories = [];
    private const int CategoryTableId = 1001;

    protected override async Task OnInitializedAsync()
    {
        loading = true;
        _categories = await GeneralValues.GetByTableIdAsync(CategoryTableId);

        if (Id is not null)
        {
            var product = await Products.GetByIdAsync(Id.Value);
            if (product is not null)
            {
                createModel.Name            = product.Name;
                createModel.SKU             = product.SKU;
                createModel.CategoryTableId = product.CategoryTableId;
                createModel.CategoryCode    = product.CategoryCode;
                createModel.UnitPrice       = product.UnitPrice;
                createModel.MinStock        = product.MinStock;
                createModel.MaxStock        = product.MaxStock;
            }
        }
        loading = false;
    }

    private void OnCategoryChange(ChangeEventArgs e)
    {
        createModel.CategoryCode    = e.Value?.ToString() ?? string.Empty;
        createModel.CategoryTableId = string.IsNullOrEmpty(createModel.CategoryCode) ? 0 : CategoryTableId;
    }

    private async Task HandleSubmit()
    {
        saving = true;
        errorMessage = null;

        if (Id is null)
        {
            var result = await Products.CreateAsync(createModel);
            if (result is not null)
            {
                await JS.InvokeVoidAsync("swalSuccess", Labels.Confirm_Saved, $"'{result.Name}' {Labels.Product_CreatedOk}");
                Navigation.NavigateTo("/products");
            }
            else
                errorMessage = Labels.Product_CreateError;
        }
        else
        {
            var result = await Products.UpdateAsync(Id.Value, new UpdateProductRequest
            {
                Name            = createModel.Name,
                CategoryTableId = createModel.CategoryTableId,
                CategoryCode    = createModel.CategoryCode,
                UnitPrice       = createModel.UnitPrice,
                MinStock        = createModel.MinStock,
                MaxStock        = createModel.MaxStock
            });
            if (result)
            {
                await JS.InvokeVoidAsync("swalSuccess", Labels.Confirm_Updated, Labels.Product_UpdatedOk);
                Navigation.NavigateTo("/products");
            }
            else
                errorMessage = Labels.Product_UpdateError;
        }
        saving = false;
    }
}
