@page "/register"
@layout EmptyLayout
@inject AuthService Auth
@inject NavigationManager Navigation

<PageTitle>Crear cuenta - NetInventory</PageTitle>

<div class="login-wrapper">
    <div class="login-card">
        <div class="login-card-header">
            <h2>Net<span>Inventory</span></h2>
            <p>Crear nueva cuenta</p>
        </div>
        <div class="login-card-body">
            <EditForm Model="model" OnValidSubmit="HandleRegister">
                <DataAnnotationsValidator />

                <div class="form-group">
                    <label>Correo electrónico</label>
                    <div class="input-group">
                        <div class="input-group-prepend">
                            <span class="input-group-text bg-white"><i class="bi bi-envelope" style="color:#1b6ec2;"></i></span>
                        </div>
                        <InputText Value="@model.Email"
                                   ValueChanged="@(v => model.Email = (v ?? string.Empty).Replace(" ", string.Empty))"
                                   ValueExpression="@(() => model.Email)"
                                   class="form-control" placeholder="usuario@empresa.com" />
                    </div>
                    <ValidationMessage For="() => model.Email" />
                </div>

                <div class="form-group">
                    <label>Contraseña</label>
                    <div class="input-group">
                        <div class="input-group-prepend">
                            <span class="input-group-text bg-white"><i class="bi bi-lock" style="color:#1b6ec2;"></i></span>
                        </div>
                        <InputText type="password" @bind-Value="model.Password" class="form-control" placeholder="Mínimo 8 caracteres" />
                    </div>
                    <ValidationMessage For="() => model.Password" />
                </div>

                @if (!string.IsNullOrEmpty(errorMessage))
                {
                    <div class="alert alert-danger py-2 mb-3" style="font-size:12px;">
                        <i class="bi bi-exclamation-circle mr-1"></i> @errorMessage
                    </div>
                }

                <button type="submit" disabled="@loading" class="btn btn-primary btn-block" style="padding:10px;">
                    @if (loading)
                    {
                        <span class="spinner-border spinner-border-sm mr-2" role="status"></span>
                        <span>Creando cuenta...</span>
                    }
                    else
                    {
                        <i class="bi bi-person-plus mr-2"></i>
                        <span>Crear cuenta</span>
                    }
                </button>
            </EditForm>

            <div class="text-center mt-3">
                <span style="font-size:12px;color:#6c757d;">¿Ya tienes cuenta?</span>
                <a href="/login" style="font-size:12px;font-weight:600;color:#1b6ec2;"> Inicia sesión</a>
            </div>
        </div>
    </div>
</div>

@code {
    private RegisterRequest model = new();
    private string? errorMessage;
    private bool loading;

    private async Task HandleRegister()
    {
        loading = true;
        errorMessage = null;
        model.Email = model.Email.Trim();
        var error = await Auth.Register(model);
        loading = false;

        if (error is null)
            Navigation.NavigateTo("/login");
        else
            errorMessage = error;
    }
}
