@page "/login"
@layout EmptyLayout
@inject AuthService Auth
@inject NavigationManager Navigation

<PageTitle>Iniciar sesión - NetInventory</PageTitle>

<div class="login-wrapper">
    <div class="login-card">
        <div class="login-card-header">
            <h2>Net<span>Inventory</span></h2>
            <p>Sistema de Gestión de Inventario</p>
        </div>
        <div class="login-card-body">
            <EditForm Model="model" OnValidSubmit="HandleLogin">
                <DataAnnotationsValidator />

                <div class="form-group">
                    <label>Correo electrónico</label>
                    <div class="input-group">
                        <div class="input-group-prepend">
                            <span class="input-group-text bg-white"><i class="bi bi-envelope text-navy"></i></span>
                        </div>
                        <InputText Value="@model.Email"
                                   ValueChanged="@(v => model.Email = (v ?? string.Empty).Replace(" ", string.Empty))"
                                   ValueExpression="@(() => model.Email)"
                                   class="form-control" placeholder="usuario@empresa.com" />
                    </div>
                    <ValidationMessage For="() => model.Email" />
                </div>

                <div class="form-group">
                    <label>Contraseña</label>
                    <div class="input-group">
                        <div class="input-group-prepend">
                            <span class="input-group-text bg-white"><i class="bi bi-lock text-navy"></i></span>
                        </div>
                        <InputText type="@(showPassword ? "text" : "password")" @bind-Value="model.Password" class="form-control" placeholder="••••••••" />
                        <div class="input-group-append">
                            <button type="button" class="btn btn-outline-secondary" @onclick="() => showPassword = !showPassword" tabindex="-1">
                                <i class="bi @(showPassword ? "bi-eye-slash" : "bi-eye")"></i>
                            </button>
                        </div>
                    </div>
                    <ValidationMessage For="() => model.Password" />
                </div>

                @if (!string.IsNullOrEmpty(errorMessage))
                {
                    <div class="alert alert-danger py-2 mb-3" style="font-size:12px;">
                        <i class="bi bi-exclamation-circle me-1"></i> @errorMessage
                    </div>
                }

                <button type="submit" disabled="@loading" class="btn btn-primary btn-block" style="padding:10px;">
                    @if (loading)
                    {
                        <span class="spinner-border spinner-border-sm mr-2" role="status"></span>
                        <span>Verificando...</span>
                    }
                    else
                    {
                        <i class="bi bi-box-arrow-in-right mr-2"></i>
                        <span>Ingresar</span>
                    }
                </button>
            </EditForm>

            <div class="text-center mt-3">
                <span style="font-size:12px;color:#74788d;">¿No tienes cuenta?</span>
                <a href="/register" style="font-size:12px;font-weight:600;color:#24356a;"> Regístrate</a>
            </div>
        </div>
    </div>
</div>

@code {
    private LoginRequest model = new();
    private string? errorMessage;
    private bool loading;
    private bool showPassword;

    private async Task HandleLogin()
    {
        loading = true;
        errorMessage = null;
        model.Email = model.Email.Trim();
        var success = await Auth.Login(model);
        loading = false;

        if (success)
            Navigation.NavigateTo("/products");
        else
            errorMessage = Labels.Auth_LoginError;
    }
}
