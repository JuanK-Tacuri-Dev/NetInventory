@inherits LayoutComponentBase
@inject AuthService Auth
@inject NavigationManager Navigation
@inject IJSRuntime JS

<div id="layout-wrapper">

    <!-- TOPBAR -->
    <header id="page-topbar">
        <div class="navbar-header">
            <div class="topbar-left">
                <button class="btn-topbar" title="Colapsar menú" @onclick="ToggleSidebar">
                    <i class="bi bi-list"></i>
                </button>
            </div>
            <div class="topbar-right">
                <AuthorizeView>
                    <Authorized>
                        <div class="topbar-user">
                            <div class="avatar">@GetInitial(context.User.Identity?.Name)</div>
                            <span class="d-none d-md-inline">@context.User.Identity?.Name</span>
                        </div>
                        <button class="btn btn-sm btn-outline-primary" style="border-radius:30px;" @onclick="Logout">
                            <i class="bi bi-box-arrow-right"></i> Salir
                        </button>
                    </Authorized>
                </AuthorizeView>
            </div>
        </div>
    </header>

    <!-- SIDEBAR -->
    <div class="vertical-menu">
        <NavMenu />
    </div>

    <!-- MAIN CONTENT -->
    <div class="main-content">
        <div class="page-content">
            @Body
        </div>
    </div>

</div>

@code {
    private async Task Logout()
    {
        await Auth.Logout();
        Navigation.NavigateTo("/login");
    }

    private async Task ToggleSidebar()
        => await JS.InvokeVoidAsync("toggleSidebar");

    private static string GetInitial(string? name)
        => string.IsNullOrWhiteSpace(name) ? "U" : name[0].ToString().ToUpper();
}
