# =============================================================
# NetInventory — Plantilla de variables de entorno
# Copiar este archivo como .env y completar los valores
# El archivo .env está en .gitignore — NUNCA commitear .env
# =============================================================

# ----- Base de datos (Docker) --------------------------------
# Contraseña para SQL Server (mínimo 8 chars, mayúscula, número y símbolo)
SA_PASSWORD=YourStrong@Password123

# ----- JWT ---------------------------------------------------
# Mínimo 32 caracteres. Usar un generador: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-minimum-32-chars!!
JWT_ISSUER=NetInventory
JWT_AUDIENCE=NetInventory
JWT_EXPIRES_MINUTES=60

# ----- CORS (producción) -------------------------------------
# URL del cliente Blazor en producción
ALLOWED_ORIGINS=https://tu-dominio.com

# ----- Cache -------------------------------------------------
CACHE_GENERAL_VALUES_MINUTES=60

# ----- Stock -------------------------------------------------
LOW_STOCK_THRESHOLD=10
