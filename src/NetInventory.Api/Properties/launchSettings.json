{
  "$schema": "http://json.schemastore.org/launchsettings.json",
  "profiles": {
    "http": {
      "commandName": "Project",
      "dotnetRunMessages": true,
      "launchBrowser": false,
      "applicationUrl": "http://localhost:5001",
      "environmentVariables": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "ConnectionStrings__Default": "Data Source=inventory.db",
        "JwtSettings__Secret": "dev-local-secret-key-minimum-32-chars!!",
        "JwtSettings__Issuer": "NetInventory",
        "JwtSettings__Audience": "NetInventory",
        "LowStockThreshold": "10",
        "CacheSettings__GeneralValuesMinutes": "60"
      }
    },
    "https": {
      "commandName": "Project",
      "dotnetRunMessages": true,
      "launchBrowser": false,
      "applicationUrl": "https://localhost:5001",
      "environmentVariables": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "ConnectionStrings__Default": "Data Source=inventory.db",
        "JwtSettings__Secret": "dev-local-secret-key-minimum-32-chars!!",
        "JwtSettings__Issuer": "NetInventory",
        "JwtSettings__Audience": "NetInventory",
        "LowStockThreshold": "10",
        "CacheSettings__GeneralValuesMinutes": "60"
      }
    }
  }
}
