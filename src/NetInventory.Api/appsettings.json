{
  "ConnectionStrings": {
    "Default": "Data Source=inventory.db"
  },
  "JwtSettings": {
    "Issuer": "NetInventory",
    "Audience": "NetInventory",
    "Secret": "#{JWT_SECRET_REPLACE_IN_PROD}#",
    "ExpiresInMinutes": 60
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information"
    }
  },
  "LowStockThreshold": 10,
  "AllowedHosts": "*"
}
