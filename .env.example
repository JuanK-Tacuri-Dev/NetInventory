# =============================================================
# NetInventory — Plantilla de variables de entorno
# Copiar como .env y completar los valores
# El archivo .env está en .gitignore — NUNCA commitear
# =============================================================

# ----- Modo de base de datos ---------------------------------
# Cambiar esta variable para apuntar a SQLite o SQL Server.
# El sistema detecta automáticamente según el valor:
#   - Contiene ".db"  → SQLite  (desarrollo local sin Docker)
#   - Otros valores   → SQL Server (Docker / producción)

# Desarrollo local (SQLite):
# CONNECTION_STRING=Data Source=inventory.db

# Docker / Producción (SQL Server):
CONNECTION_STRING=Server=sqlserver;Database=NetInventory;User Id=sa;Password=YourStrong@Password123;TrustServerCertificate=True

# ----- SQL Server (solo necesario cuando usas SQL Server) ----
SA_PASSWORD=YourStrong@Password123

# ----- JWT ---------------------------------------------------
# Mínimo 32 caracteres. Generar con: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-minimum-32-chars!!
